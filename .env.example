# Strapi CMS Configuration

# 开发环境 - 本地 Strapi
VITE_STRAPI_URL=http://localhost:1337

# 生产环境 - 你的服务器地址
# VITE_STRAPI_URL=https://api.your-domain.com

# 示例：如果你的服务器 IP 是 123.456.789.0
# VITE_STRAPI_URL=http://123.456.789.0:1337

# 注意：GitHub Pages 是 HTTPS，Strapi 也需要 HTTPS
# 或者使用 Cloudflare Tunnel / ngrok 等工具
