# Noveris Blog Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Public Variables (exposed to client)
# ============================================

# Site URL
NUXT_PUBLIC_SITE_URL=https://noveris-ai.github.io

# API URL (Vercel Functions)
NUXT_PUBLIC_API_URL=https://noveris-blog-auth.vercel.app

# Meilisearch (Search)
NUXT_PUBLIC_MEILISEARCH_HOST=
NUXT_PUBLIC_MEILISEARCH_SEARCH_KEY=

# Giscus (Comments)
NUXT_PUBLIC_GISCUS_REPO=Noveris-AI/Noveris-AI.github.io
NUXT_PUBLIC_GISCUS_REPO_ID=
NUXT_PUBLIC_GISCUS_CATEGORY=Comments
NUXT_PUBLIC_GISCUS_CATEGORY_ID=

# Sentry (Error Monitoring)
NUXT_PUBLIC_SENTRY_DSN=

# ============================================
# Private Variables (server-side only)
# ============================================

# Meilisearch Admin Key (for indexing)
NUXT_MEILISEARCH_API_KEY=

# Email (for contact form)
NUXT_EMAIL_PASSWORD=

# GitHub OAuth (for CMS)
NUXT_GITHUB_CLIENT_SECRET=
